{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "jsx": "react-jsx",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/client/**/*",
        "src/server/**/*",
        "src/shared/**/*"
    ]
}